# --- Directorios de compilación y salida ---
[Bb]in/
[Ob]j/
out/

# --- Herramientas de .NET ---
.dotnet/
project.lock.json
project.fragment.lock.json
artifacts/

# --- Paquetes NuGet ---
*.nupkg
# No ignorar la carpeta de paquetes si usas el estilo antiguo de packages.config, 
# pero para .NET Core/5+ se manejan globalmente.
**/packages/*
!**/packages/build/

# --- VS Code ---
.vscode/
# Nota: Si quieres compartir la configuración de depuración con tu equipo, 
# comenta la línea de arriba y usa estas:
# .vscode/tasks.json
# .vscode/launch.json
# .vscode/settings.json

# --- User-specific files ---
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# --- Archivos temporales y de SO ---
.DS_Store
Thumbs.db
log.txt
*.log